{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://relux-works.github.io/curator-spec/schemas/v1/registry-log-entry-v1.schema.json",
  "title": "Curator registry log entry schema 1",
  "type": "object",
  "required": ["seq", "entry_hash", "prev_hash", "record"],
  "properties": {
    "seq": {"type": "integer", "minimum": 1, "maximum": 9007199254740991},
    "entry_hash": {"$ref": "common.schema.json#/$defs/hex256"},
    "prev_hash": {"$ref": "common.schema.json#/$defs/hex256"},
    "record": {"$ref": "audit-record-v1.schema.json"}
  },
  "additionalProperties": false
}
