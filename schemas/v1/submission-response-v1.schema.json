{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://relux-works.github.io/curator-spec/schemas/v1/submission-response-v1.schema.json",
  "title": "Registry submission response",
  "type": "object",
  "required": ["seq", "entry_hash"],
  "properties": {
    "seq": {"type": "integer", "minimum": 1, "maximum": 9007199254740991},
    "entry_hash": {"$ref": "common.schema.json#/$defs/hex256"}
  },
  "additionalProperties": false
}
