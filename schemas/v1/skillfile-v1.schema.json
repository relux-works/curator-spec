{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://relux-works.github.io/curator-spec/schemas/v1/skillfile-v1.schema.json",
  "title": "Skillfile.json schema 1",
  "type": "object",
  "required": ["schema_version", "skills"],
  "properties": {
    "schema_version": {"const": 1},
    "project": {
      "type": "object",
      "properties": {"alias": {"$ref": "common.schema.json#/$defs/identifier"}},
      "additionalProperties": false
    },
    "agents": {"$ref": "common.schema.json#/$defs/identifierSet"},
    "locale": {"type": "string", "minLength": 1, "maxLength": 64},
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {"$ref": "common.schema.json#/$defs/identifier"},
          "source": {"$ref": "common.schema.json#/$defs/portablePath"},
          "git": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
          "tag": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
          "branch": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
          "revision": {"$ref": "common.schema.json#/$defs/nonEmptyString"}
        },
        "oneOf": [{"required": ["tag"]}, {"required": ["branch"]}, {"required": ["revision"]}],
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
