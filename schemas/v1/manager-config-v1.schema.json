{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://relux-works.github.io/curator-spec/schemas/v1/manager-config-v1.schema.json",
  "title": "Curator manager logical configuration schema 1",
  "type": "object",
  "required": ["schema_version", "skills_root", "projects"],
  "properties": {
    "schema_version": {"const": 1},
    "skills_root": {"type": "string", "minLength": 1, "maxLength": 4096},
    "default_agents": {"$ref": "common.schema.json#/$defs/identifierSet"},
    "preferred_locale": {"type": "string", "minLength": 1, "maxLength": 64},
    "adapter_mode": {"enum": ["auto", "symlink", "copy"], "default": "auto"},
    "worktree_alias_pattern": {"type": "string", "minLength": 1, "maxLength": 1024},
    "projects": {
      "type": "object",
      "propertyNames": {"$ref": "common.schema.json#/$defs/identifier"},
      "additionalProperties": {
        "type": "object",
        "required": ["path"],
        "properties": {
          "path": {"type": "string", "minLength": 1, "maxLength": 4096},
          "agents": {"$ref": "common.schema.json#/$defs/identifierSet"},
          "project_alias": {"$ref": "common.schema.json#/$defs/identifier"},
          "checkout_alias": {"$ref": "common.schema.json#/$defs/identifier"}
        },
        "additionalProperties": false
      }
    },
    "allowed_sources": {"type": "array", "items": {"type": "string", "minLength": 1, "maxLength": 4096}, "uniqueItems": true},
    "audit": {"$ref": "#/$defs/audit"},
    "audit_registries": {
      "type": "array",
      "items": {"$ref": "#/$defs/registry"}
    },
    "disable_builtin_registries": {"type": "boolean", "default": false}
  },
  "additionalProperties": false,
  "$defs": {
    "registry": {
      "type": "object",
      "required": ["name", "url", "public_keys", "enabled"],
      "properties": {
        "name": {"$ref": "common.schema.json#/$defs/identifier"},
        "url": {"type": "string", "pattern": "^https?://[^\\s]+$", "maxLength": 4096},
        "public_keys": {"type": "array", "items": {"type": "string", "pattern": "^(?:ed25519:)?[A-Za-z0-9+/]{43}=$"}, "uniqueItems": true},
        "enabled": {"type": "boolean"},
        "required": {"type": "boolean", "default": false}
      },
      "additionalProperties": false
    },
    "audit": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean", "default": false},
        "mode": {"enum": ["advisory", "strict"], "default": "advisory"},
        "fail_on": {"enum": ["off", "low", "medium", "high", "critical"], "default": "high"},
        "backend": {"type": "string"},
        "model": {"type": "string"},
        "allow_cloud": {"type": "boolean"},
        "backends": {"type": "object"},
        "grants": {"type": "array", "items": {"type": "object"}},
        "revocations": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "source_policy": {"type": "object"},
        "registry_policy": {"enum": ["advisory", "strict"], "default": "advisory"},
        "snapshot_max_age_seconds": {"type": "integer", "minimum": 1},
        "snapshot_clock_skew_seconds": {"type": "integer", "minimum": 0},
        "cache_ttl_seconds": {"type": "integer", "minimum": 0},
        "offline_grace_seconds": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    }
  }
}
