{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://relux-works.github.io/curator-spec/schemas/v1/common.schema.json",
  "title": "Curator Protocol common definitions",
  "$defs": {
    "identifier": {
      "allOf": [
        {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$", "maxLength": 128},
        {"not": {"pattern": "^(?:[Cc][Oo][Nn]|[Pp][Rr][Nn]|[Aa][Uu][Xx]|[Nn][Uu][Ll]|[Cc][Oo][Mm][1-9]|[Ll][Pp][Tt][1-9])(?:\\.|$)"}}
      ]
    },
    "portablePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4096,
      "pattern": "^[^/\\\\:\\u0000-\\u001f](?:[^\\\\:\\u0000-\\u001f]*[^/ .\\\\:\\u0000-\\u001f])?$",
      "not": {"pattern": "(?:^|/)(?:\\.{1,2}|[Cc][Oo][Nn]|[Pp][Rr][Nn]|[Aa][Uu][Xx]|[Nn][Uu][Ll]|[Cc][Oo][Mm][1-9]|[Ll][Pp][Tt][1-9])(?:\\.|/|$)|//"}
    },
    "nonEmptyString": {"type": "string", "minLength": 1, "maxLength": 8192},
    "safeInteger": {"type": "integer", "minimum": -9007199254740991, "maximum": 9007199254740991},
    "nonNegativeSafeInteger": {"type": "integer", "minimum": 0, "maximum": 9007199254740991},
    "sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "hex256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "commit": {"type": "string", "pattern": "^[0-9a-f]{40}(?:[0-9a-f]{24})?$"},
    "timestamp": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"},
    "stringSet": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "identifierSet": {"type": "array", "items": {"$ref": "#/$defs/identifier"}, "uniqueItems": true},
    "pathSet": {"type": "array", "items": {"$ref": "#/$defs/portablePath"}, "uniqueItems": true},
    "ref": {
      "type": "object",
      "required": ["kind", "value"],
      "properties": {
        "kind": {"enum": ["tag", "revision"]},
        "value": {"type": "string", "minLength": 1, "maxLength": 1024, "pattern": "^[^\\s\\^~><*]+$"}
      },
      "additionalProperties": false
    },
    "devRef": {
      "type": "object",
      "required": ["kind", "value"],
      "properties": {
        "kind": {"enum": ["tag", "revision", "branch"]},
        "value": {"type": "string", "minLength": 1, "maxLength": 1024}
      },
      "additionalProperties": false
    },
    "scriptCommand": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {"const": "script"},
        "unix_path": {"$ref": "#/$defs/portablePath"},
        "win_path": {"$ref": "#/$defs/portablePath"}
      },
      "anyOf": [{"required": ["unix_path"]}, {"required": ["win_path"]}],
      "additionalProperties": false
    },
    "systemCommand": {
      "type": "object",
      "required": ["type", "command"],
      "properties": {
        "type": {"const": "system"},
        "command": {"$ref": "#/$defs/identifier"},
        "hint": {"$ref": "#/$defs/nonEmptyString"}
      },
      "additionalProperties": false
    },
    "command": {"oneOf": [{"$ref": "#/$defs/scriptCommand"}, {"$ref": "#/$defs/systemCommand"}]},
    "legacySkillCommand": {
      "type": "object",
      "required": ["type", "skill", "command"],
      "properties": {
        "type": {"const": "skill"},
        "skill": {"$ref": "#/$defs/identifier"},
        "command": {"$ref": "#/$defs/identifier"},
        "hint": {"$ref": "#/$defs/nonEmptyString"}
      },
      "additionalProperties": false
    },
    "capabilities": {
      "type": "object",
      "properties": {
        "network": {
          "oneOf": [
            {"const": "none"},
            {"type": "array", "items": {"type": "string", "minLength": 1, "pattern": "^[^\\s/\\\\]+$"}, "uniqueItems": true}
          ],
          "default": "none"
        },
        "filesystem": {
          "oneOf": [
            {"enum": ["repo", "home-config"]},
            {"$ref": "#/$defs/pathSet"}
          ],
          "default": "repo"
        },
        "exec": {
          "oneOf": [{"const": "none"}, {"$ref": "#/$defs/identifierSet"}],
          "default": "none"
        },
        "secrets": {
          "oneOf": [{"const": "none"}, {"$ref": "#/$defs/stringSet"}],
          "default": "none"
        },
        "env_read": {
          "type": "array",
          "items": {"type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"},
          "uniqueItems": true,
          "default": []
        },
        "prompt_scope": {"$ref": "#/$defs/nonEmptyString"}
      },
      "additionalProperties": false
    },
    "skillRequirement": {
      "type": "object",
      "required": ["git", "ref"],
      "properties": {
        "git": {"$ref": "#/$defs/nonEmptyString"},
        "ref": {"$ref": "#/$defs/ref"},
        "mode": {"enum": ["full", "runtime", "context"], "default": "full"},
        "commands": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/identifier"}, "uniqueItems": true}
      },
      "allOf": [
        {"if": {"required": ["commands"]}, "then": {"properties": {"mode": {"const": "runtime"}}, "required": ["mode"]}}
      ],
      "additionalProperties": false
    },
    "mcpRequirement": {
      "type": "object",
      "required": ["hint"],
      "properties": {
        "hint": {"$ref": "#/$defs/nonEmptyString"},
        "transport": {"enum": ["stdio", "http"]},
        "required_in": {"enum": ["any", "all"], "default": "any"}
      },
      "additionalProperties": false
    },
    "dependenciesV2": {
      "type": "object",
      "properties": {
        "commands": {"type": "object", "additionalProperties": {"oneOf": [{"$ref": "#/$defs/systemCommand"}, {"$ref": "#/$defs/legacySkillCommand"}]}}
      },
      "additionalProperties": false
    },
    "dependenciesV4": {
      "type": "object",
      "properties": {
        "commands": {"type": "object", "additionalProperties": {"oneOf": [{"$ref": "#/$defs/systemCommand"}, {"$ref": "#/$defs/legacySkillCommand"}]}},
        "skills": {"type": "object", "additionalProperties": {"$ref": "#/$defs/skillRequirement"}}
      },
      "additionalProperties": false
    },
    "dependenciesV5": {
      "type": "object",
      "properties": {
        "commands": {"type": "object", "additionalProperties": {"oneOf": [{"$ref": "#/$defs/systemCommand"}, {"$ref": "#/$defs/legacySkillCommand"}]}},
        "skills": {"type": "object", "additionalProperties": {"$ref": "#/$defs/skillRequirement"}},
        "mcp_servers": {"type": "object", "additionalProperties": {"$ref": "#/$defs/mcpRequirement"}}
      },
      "additionalProperties": false
    },
    "signature": {
      "type": "object",
      "required": ["algorithm", "key_id", "signature"],
      "properties": {
        "algorithm": {"const": "ed25519"},
        "key_id": {"type": "string", "pattern": "^[0-9a-f]{16}$"},
        "signature": {"type": "string", "pattern": "^[A-Za-z0-9+/]{86}==$"}
      },
      "additionalProperties": false
    },
    "canonicalValue": {
      "oneOf": [
        {"type": "null"},
        {"type": "boolean"},
        {"$ref": "#/$defs/safeInteger"},
        {"type": "string"},
        {"type": "array", "items": {"$ref": "#/$defs/canonicalValue"}},
        {"type": "object", "additionalProperties": {"$ref": "#/$defs/canonicalValue"}}
      ]
    }
  }
}
